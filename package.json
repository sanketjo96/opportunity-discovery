{
  "name": "opp-discovery-api",
  "version": "1.0.0",
  "private": true,
  "description": "Opportunity Discovery — ingest webhook API",
  "main": "dist/server.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && node ./node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bullmq": "^5.71.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.10.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
